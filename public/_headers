# Static headers for docs.aggregator.gg.
# Search-engine preview-URL blocking is configured at the Cloudflare Pages
# level (Settings → Branch deploys → Production: docs.aggregator.gg only;
# preview branches get auto-generated *.aggregator-docs.pages.dev URLs
# which are excluded from sitemap and emit X-Robots-Tag: noindex via the
# build).

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
